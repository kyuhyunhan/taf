{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-swift-edit.sh"
          },
          {
            "type": "command",
            "command": "$TAF_ROOT/runtime/hooks/post-resolve-edit.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$TAF_ROOT/runtime/hooks/pre-bash-guard.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$TAF_ROOT/runtime/hooks/pre-memory-write.sh"
          },
          {
            "type": "command",
            "command": "$TAF_ROOT/runtime/hooks/pre-edit-agent-required.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-edit-config-warn.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-holds-edit.sh"
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "$TAF_ROOT/runtime/hooks/pre-task.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/scripts/lifecycle/auto-commit-repos.sh session-end"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$TAF_ROOT/runtime/hooks/session-init.sh"
          },
          {
            "type": "command",
            "command": "\"$TAF_ROOT/scripts/forge-sync-memory\" lexio"
          }
        ]
      }
    ]
  }
}
